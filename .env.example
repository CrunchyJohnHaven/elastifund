# Elastifund — Environment Variables
# Copy this to .env and fill in your values

# ===========================================
# Elastifund.io Hub Stack (Instance 1.1)
# Root docker-compose.yml uses these settings.
# ===========================================
ELASTIC_VERSION=8.15.5
ELASTIC_CLUSTER_NAME=elastifund-hub
ELASTIC_JAVA_HEAP=1g
ELASTIC_PASSWORD=replace-me-generated-by-setup
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_VERIFY_CERTS=false
ELASTICSEARCH_PORT=9200

KIBANA_SYSTEM_PASSWORD=replace-me-generated-by-setup
KIBANA_ENCRYPTION_KEY=replace-me-generated-by-setup
KIBANA_PORT=5601

KAFKA_IMAGE=bitnami/kafka:3.7.0
KAFKA_PORT=29092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=elastifund-hub

REDIS_IMAGE=redis:7-alpine
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

HUB_ENV=local
HUB_APP_NAME="Elastifund Hub Gateway"
HUB_GATEWAY_PORT=8080
ELASTIFUND_GATEWAY_URL=http://hub-gateway:8080
ELASTIFUND_AGENT_INDEX=elastifund-agents
ELASTIFUND_AGENT_NAME=template-agent
ELASTIFUND_AGENT_HEARTBEAT_SECONDS=60
ELASTIFUND_AGENT_TELEMETRY_ENABLED=true
ELASTIFUND_INDICES=elastifund-strategies,elastifund-metrics,elastifund-trades,elastifund-knowledge,elastifund-agents
ELASTIFUND_TOPICS=strategy.fingerprints,strategy.updates.trading,strategy.updates.non_trading,performance.attestations,market.regime.changes,risk.alerts,knowledge.discoveries

# ===========================================
# Fork-and-run onboarding (Instance 8.1)
# Generated defaults can be written by:
#   python3 scripts/elastifund_setup.py
# If you are joining another person's running instance, ask them for:
#   -- their public hub URL
#   -- their hub bootstrap token
# ===========================================
ELASTIFUND_PROFILE=local
ELASTIFUND_AGENT_ID=
ELASTIFUND_AGENT_SECRET=
ELASTIFUND_HUB_URL=http://hub-gateway:8080
ELASTIFUND_HUB_EXTERNAL_URL=http://localhost:8080
ELASTIFUND_HUB_BOOTSTRAP_TOKEN=replace-me-generated-by-setup
ELASTIFUND_HUB_REGISTRY_PATH=state/elastifund/registry.json
ELASTIFUND_ENABLE_TRADING=true
ELASTIFUND_ENABLE_DIGITAL_PRODUCTS=true
ELASTIFUND_AGENT_RUN_MODE=paper
ELASTIFUND_LLM_PROVIDER=anthropic
ELASTIFUND_NONPROFIT=veteran-suicide-prevention
ELASTIFUND_DONATION_PERCENT=20
ELASTIFUND_INITIAL_CAPITAL_USD=250
ELASTIFUND_TRADING_CAPITAL_PCT=70
ELASTIFUND_DIGITAL_CAPITAL_PCT=30
ELASTIFUND_ELASTICSEARCH_HOST=elasticsearch
ELASTIFUND_ELASTICSEARCH_PORT=9200
ELASTIFUND_KIBANA_HOST=kibana
ELASTIFUND_KIBANA_PORT=5601
ELASTIFUND_KAFKA_HOST=kafka
ELASTIFUND_KAFKA_PORT=9092
ELASTIFUND_REDIS_HOST=redis
ELASTIFUND_REDIS_PORT=6379

# ===========================================
# Polymarket CLOB API Credentials
# Get from: polymarket.com/settings?tab=builder
# ===========================================
POLYMARKET_API_KEY=your-api-key-here
POLYMARKET_API_SECRET=your-api-secret-here
POLYMARKET_API_PASSPHRASE=your-api-passphrase-here
POLYMARKET_FUNDER=0xYourPolymarketWalletAddress
POLYMARKET_PK=your-private-key-here-without-0x-prefix

# Duplicate for py-clob-client compatibility (EOA signer address)
POLY_SAFE_ADDRESS=0xYourPolymarketWalletAddress
# Proxy wallet address for data-API position queries (may differ from signer with POLY_PROXY)
POLY_DATA_API_ADDRESS=0xYourProxyWalletAddress
POLY_BUILDER_API_KEY=your-api-key-here
POLY_BUILDER_API_SECRET=your-api-secret-here
POLY_BUILDER_API_PASSPHRASE=your-api-passphrase-here

# ===========================================
# LLM API Keys (for probability estimation)
# ===========================================

# Required: At least one of these
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Free: Groq (console.groq.com — no credit card needed)
GROQ_API_KEY=your-groq-api-key-here

# Optional: OpenAI (for GPT-4o Mini diversity in ensemble)
OPENAI_API_KEY=your-openai-api-key-here

# Optional: xAI (for Grok-3 diversity in ensemble)
XAI_API_KEY=xai-your-key-here

# Claude model for single-model mode
CLAUDE_MODEL=claude-haiku-4-5-20241022

# ===========================================
# Telegram Notifications (optional)
# ===========================================
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ===========================================
# Kalshi (optional — for cross-platform trading)
# ===========================================
KALSHI_API_KEY_ID=your-kalshi-key-id-here
KALSHI_RSA_KEY_PATH=kalshi/kalshi_rsa_private.pem

# ===========================================
# Etsy / digital products (optional)
# ===========================================
ETSY_API_KEY=your-etsy-api-key-here
ETSY_SHOP_ID=your-shop-id-here

# ===========================================
# Calibration (Platt scaling)
# Fit these on your own resolved-market dataset.
# Exact live coefficients are intentionally omitted from the public repo.
# ===========================================
PLATT_A=0.5914
PLATT_B=-0.3977

# Experimental: adaptive rolling calibration + conviction filters
JJ_ADAPTIVE_PLATT_ENABLED=false
JJ_ADAPTIVE_PLATT_MIN_SAMPLES=50
JJ_ADAPTIVE_PLATT_WINDOW=100
JJ_ADAPTIVE_PLATT_REFIT_SECONDS=300
JJ_MAX_KELLY_FRACTION=0.25
JJ_DISAGREEMENT_CONFIRMATION_STD=0.05
JJ_DISAGREEMENT_SIGNAL_STD=0.10
JJ_DISAGREEMENT_REDUCE_SIZE_STD=0.15
JJ_DISAGREEMENT_WIDE_STD=0.20
JJ_ENSEMBLE_DAILY_COST_CAP_USD=2.0
JJ_ENSEMBLE_ENABLE_SECOND_CLAUDE=false
JJ_OPENAI_ENSEMBLE_MODEL=gpt-4o-mini
JJ_OPENAI_INPUT_COST_PER_M=0.15
JJ_OPENAI_OUTPUT_COST_PER_M=0.60

# ===========================================
# Infrastructure (VPS deploy — optional)
# ===========================================
# VPS_IP=your-vps-ip-here
# LIGHTSAIL_KEY=~/.ssh/lightsail.pem

# ===========================================
# GitHub self-push (optional for unattended flywheel publishing)
# Put secrets in .env only; never commit them.
# ===========================================
# ELASTIFUND_AUTO_PUSH_GITHUB=true
# ELASTIFUND_GITHUB_SSH_KEY=~/.ssh/id_ed25519
# ELASTIFUND_GITHUB_TOKEN=github_pat_your_token_here

# ===========================================
# Elastic Hub Bootstrap (Elastifund.io control plane)
# ===========================================
# Use either an already-encoded ELASTIC_API_KEY or an "id:api_key" pair.
# ELASTICSEARCH_URL=https://your-elastic-cluster:9200
# ELASTIC_API_KEY=
# ELASTIC_USERNAME=
# ELASTIC_PASSWORD=
# ELASTIC_SNAPSHOT_REPOSITORY=elastifund-snapshots
# ELASTIC_VECTOR_DIMS=768
# ELASTIC_VERIFY_TLS=true
# ELASTIC_TIMEOUT_SECONDS=30

# ===========================================
# Trading Mode
# ===========================================
# Checked-in runtime profile selector. This is the primary non-secret control
# plane for threshold and launch posture selection:
#   blocked_safe
#   shadow_fast_flow
#   research_scan
JJ_RUNTIME_PROFILE=blocked_safe

# Temporary compatibility block until bot/execution wiring consumes
# JJ_RUNTIME_PROFILE directly. Keep these aligned with the selected profile.
# After the runtime-profile contract is fully wired, leave these unset unless
# you intentionally want a one-off override.
# Set to false for LIVE trading (real money!)
PAPER_TRADING=true
ENABLE_LLM_SIGNALS=true
ENABLE_WALLET_FLOW=false
ENABLE_LMSR=false
ENABLE_CROSS_PLATFORM_ARB=false
JJ_FAST_FLOW_ONLY=false

# Wallet flow detector v1 (paper-first defaults)
# ENABLE_WALLET_FLOW toggles source wiring inside jj_live;
# WALLET_FLOW_ENABLED gates scan_for_signals() inside bot/wallet_flow_detector.py.
WALLET_FLOW_ENABLED=false
WALLET_FLOW_TOP_K=10
WALLET_FLOW_MIN_CONSENSUS=3
WALLET_FLOW_POLL_INTERVAL_SEC=15
WALLET_FLOW_LOOKBACK_SEC=300
WALLET_FLOW_KELLY_FRACTION=0.0625
WALLET_FLOW_SIGNAL_LOG_FILE=data/wallet_flow_signals.log
WALLET_FLOW_SCORED_FILE=data/smart_wallets_scored.json
# WALLET_FLOW_MARKET_IDS=0xconditionid1,0xconditionid2

# ===========================================
# JJ Parameters (temporary compatibility overrides for blocked_safe)
# ===========================================
JJ_MAX_POSITION_USD=5
JJ_MAX_DAILY_LOSS_USD=5
JJ_MAX_EXPOSURE_PCT=0.10
JJ_KELLY_FRACTION=0.125
JJ_MAX_KELLY_FRACTION=0.25
JJ_SCAN_INTERVAL=300
JJ_MAX_OPEN_POSITIONS=5
JJ_MIN_EDGE=0.05
JJ_INITIAL_BANKROLL=250.0

# ===========================================
# Runtime profile compatibility overrides
# Checked-in profiles under config/runtime_profiles/ are canonical.
# ===========================================
JJ_YES_THRESHOLD=0.15       # Edge required on YES side
JJ_NO_THRESHOLD=0.05        # Edge required on NO side
JJ_MIN_CATEGORY_PRIORITY=1  # Min category score to analyze
JJ_MAX_RESOLUTION_HOURS=48  # Max hours to resolution
JJ_LMSR_THRESHOLD=0.05

# Category priority overrides (leave unset unless you need a one-off tweak)
# JJ_CAT_PRIORITY_CRYPTO=2
# JJ_CAT_PRIORITY_SPORTS=2
# JJ_CAT_PRIORITY_GEOPOLITICAL=2
# JJ_CAT_PRIORITY_UNKNOWN=1

# ===========================================
# Combinatorial Arb Integration (A-6 / B-1)
# Checked-in profiles are canonical; these remain compatibility overrides.
# ===========================================
ENABLE_A6_SHADOW=false
ENABLE_A6_LIVE=false
ENABLE_B1_SHADOW=false
ENABLE_B1_LIVE=false
JJ_A6_BUY_THRESHOLD=0.97
JJ_A6_UNWIND_THRESHOLD=1.03
JJ_B1_IMPLICATION_THRESHOLD=0.03
JJ_COMBINATORIAL_STALE_BOOK_MAX_AGE_SECONDS=45
JJ_COMBINATORIAL_FILL_TIMEOUT_SECONDS=3.0
# JJ_COMBINATORIAL_FILL_TIMEOUT_MS=3000  # Legacy alias; seconds key wins if both are set.
JJ_COMBINATORIAL_CANCEL_REPLACE_COUNT=1
JJ_COMBINATORIAL_MAX_NOTIONAL_PER_LEG_USD=5
JJ_COMBINATORIAL_ARB_BUDGET_USD=100
JJ_COMBINATORIAL_MERGE_MIN_NOTIONAL_USD=20
JJ_COMBINATORIAL_PROMOTION_MIN_SIGNALS=20
JJ_COMBINATORIAL_REQUIRED_CAPTURE_RATE=0.50
JJ_COMBINATORIAL_REQUIRED_CLASSIFICATION_ACCURACY=0.80
JJ_COMBINATORIAL_MAX_FALSE_POSITIVE_RATE=0.05
JJ_COMBINATORIAL_MAX_CONSECUTIVE_ROLLBACKS=3
JJ_CONSTRAINT_ARB_DB_PATH=data/constraint_arb.db
JJ_DEP_GRAPH_DB_PATH=data/dep_graph.sqlite
JJ_A6_EMBEDDED_SHADOW_SCANNER=true

# ===========================================
# Microstructure thresholds (VPIN / WS defense)
# ===========================================
JJ_VPIN_BUCKET_SIZE=500
JJ_VPIN_WINDOW=10
JJ_VPIN_TOXIC_THRESHOLD=0.75
JJ_VPIN_SAFE_THRESHOLD=0.25
JJ_WS_HEARTBEAT_INTERVAL=10
JJ_WS_REST_POLL_INTERVAL=5

# ===========================================
# Instance 5: Kalshi weather arb (paper by default)
# ===========================================
KALSHI_WEATHER_EDGE_THRESHOLD=0.10
KALSHI_WEATHER_MAX_SPREAD=0.15
KALSHI_WEATHER_TEMP_STD_F=3.0
KALSHI_WEATHER_MAKER_OFFSET_CENTS=1
KALSHI_WEATHER_BANKROLL_USD=25
KALSHI_WEATHER_MAX_ORDER_USD=5
KALSHI_WEATHER_KELLY_FRACTION=0.25
KALSHI_WEATHER_MAX_PAGES=3
KALSHI_WEATHER_MAX_SIGNALS=20
KALSHI_WEATHER_MAX_ORDERS=5
KALSHI_WEATHER_PAPER_TRADING=true

# ===========================================
# Instance 5: Kalshi LLM-edge opportunity scan
# ===========================================
KALSHI_SCAN_MAX_EVENT_PAGES=8
KALSHI_SCAN_EVENTS_PAGE_LIMIT=200
KALSHI_SCAN_MARKET_LIMIT_PER_EVENT=200
KALSHI_SCAN_MAX_HOURS=72
KALSHI_SCAN_TOP_N=20
KALSHI_SCAN_SLEEP_SECONDS=0.06

# ===========================================
# Instance 2: BTC 5m Maker Bot (bot/btc_5min_maker.py)
# ===========================================
# BTC5_PAPER_TRADING=true
# BTC5_BANKROLL_USD=250
# BTC5_RISK_FRACTION=0.01
# BTC5_MAX_TRADE_USD=2.50
# BTC5_MIN_TRADE_USD=0.25
# BTC5_MIN_DELTA=0.0003
# BTC5_MAX_BUY_PRICE=0.95
# BTC5_MIN_BUY_PRICE=0.90
# BTC5_TICK_SIZE=0.01
# BTC5_ENTRY_SECONDS_BEFORE_CLOSE=10
# BTC5_CANCEL_SECONDS_BEFORE_CLOSE=2
# BTC5_DAILY_LOSS_LIMIT_USD=5
# BTC5_PAPER_FILL_PROBABILITY=0.20
# BTC5_CLOB_FEE_RATE_BPS=0

# ===========================================
# Orchestration Allocator (Phase 5.1)
# ===========================================
JJ_ALLOCATOR_MODE=three_layer
JJ_ALLOCATOR_ENABLE_THOMPSON_SAMPLING=true
JJ_ALLOCATOR_TRADING_DAILY_BUDGET_USD=100
JJ_ALLOCATOR_NON_TRADING_DAILY_SEND_QUOTA=100
JJ_ALLOCATOR_NON_TRADING_DAILY_LLM_TOKENS=50000
JJ_ALLOCATOR_FIXED_TRADING_SHARE=0.80
JJ_ALLOCATOR_MIN_NON_TRADING_SHARE=0.10
JJ_ALLOCATOR_MIN_OBSERVATIONS_PER_ARM=5
JJ_ALLOCATOR_OBSERVATION_LOOKBACK_DAYS=90
JJ_ALLOCATOR_RISK_PARITY_MIN_OBSERVATIONS=20
JJ_ALLOCATOR_THOMPSON_DISCOUNT_GAMMA=0.995
JJ_ALLOCATOR_THOMPSON_TILT_MAX_PCT=0.35
JJ_ALLOCATOR_AGENT_MIN_SHARE=0.15
JJ_ALLOCATOR_AGENT_MAX_SHARE=0.85
JJ_ALLOCATOR_CASH_RESERVE_MIN_SHARE=0.10
JJ_ALLOCATOR_CASH_RESERVE_YELLOW_SHARE=0.15
JJ_ALLOCATOR_CASH_RESERVE_MAX_SHARE=0.20
JJ_ALLOCATOR_KELLY_BOOTSTRAP_OBSERVATIONS=21
JJ_ALLOCATOR_KELLY_HIGH_CONFIDENCE_OBSERVATIONS=63
JJ_ALLOCATOR_KELLY_BOOTSTRAP_FRACTION=0.25
JJ_ALLOCATOR_KELLY_MEDIUM_FRACTION=0.3333333333
JJ_ALLOCATOR_KELLY_HIGH_FRACTION=0.50
JJ_ALLOCATOR_CUSUM_THRESHOLD_SIGMA=3.0

# ===========================================
# Non-trading Digital Products (Instance 7)
# ===========================================
# JJ_DP_DB_PATH=data/digital_products.db
# JJ_DP_EXPORT_DIR=data/digital_product_exports
# JJ_DP_MARKETPLACE=etsy
# JJ_DP_RESULT_LIMIT=25
# JJ_DP_EMBEDDING_DIMS=768
# JJ_DP_COMPETITION_FLOOR=1
# JJ_DP_MIN_MONTHLY_DEMAND=0
# JJ_DP_MIN_AVG_PRICE=0
# JJ_DP_ELASTIC_INDEX=elastifund-knowledge
