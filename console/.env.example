# For Replit deployment -- set these as Replit Secrets
# These are used at BUILD TIME by Vite (prefix VITE_ required)

# Your tunnel URL (from running tunnel.sh on your Mac)
VITE_API_URL=https://your-tunnel-url.trycloudflare.com/api
VITE_WS_URL=wss://your-tunnel-url.trycloudflare.com

# For local development, leave these unset (defaults to same host via Vite proxy)
