# DOGE 5-minute maker overrides.
# Loaded after shared strategy + capital-stage env for doge-5min-maker.service.

# 24h Binance 5m realized-vol ratio vs BTC: ~1.65x.
# Keep a wider max delta (>= 0.015) to avoid filtering most DOGE windows.
BTC5_MIN_BUY_PRICE=0.90
BTC5_UP_MAX_BUY_PRICE=0.95
BTC5_DOWN_MAX_BUY_PRICE=0.95
BTC5_MIN_DELTA=0.00020
BTC5_MAX_ABS_DELTA=0.0150
BTC5_PROBE_MAX_ABS_DELTA=0.0150
BTC5_RISK_FRACTION=0.07
