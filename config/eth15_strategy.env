# ETH 15-minute maker strategy overrides.
# Conservative launch profile for first 24h in live mode.

# Timeframe activation (handled by dynamic window code in maker core)
BTC5_WINDOW_SECONDS=900
BTC5_BINANCE_KLINE_INTERVAL=15m
BTC5_ENTRY_SECONDS_BEFORE_CLOSE=15
BTC5_CANCEL_SECONDS_BEFORE_CLOSE=3

# Conservative directional guardrails
BTC5_DIRECTIONAL_MODE=two_sided
BTC5_MIN_BUY_PRICE=0.90
BTC5_UP_MAX_BUY_PRICE=0.95
BTC5_DOWN_MAX_BUY_PRICE=0.95
BTC5_MAX_ABS_DELTA=0.0100

# Start small while collecting first 24h evidence
BTC5_RISK_FRACTION=0.10
BTC5_MAX_TRADE_USD=5.00
BTC5_MIN_TRADE_USD=5.00

# Keep spread-capture disabled for directional rollout
BTC5_ENABLE_SPREAD_CAPTURE=0
