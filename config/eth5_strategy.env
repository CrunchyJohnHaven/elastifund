# ETH 5-minute maker overrides.
# Loaded after shared strategy + capital-stage env for eth-5min-maker.service.

# 24h Binance 5m realized-vol ratio vs BTC: ~1.51x.
# Widen delta guardrails proportionally to avoid over-skipping fast ETH candles.
BTC5_MIN_BUY_PRICE=0.90
BTC5_UP_MAX_BUY_PRICE=0.95
BTC5_DOWN_MAX_BUY_PRICE=0.95
BTC5_MIN_DELTA=0.00015
BTC5_MAX_ABS_DELTA=0.0070
BTC5_PROBE_MAX_ABS_DELTA=0.0070
BTC5_RISK_FRACTION=0.10
