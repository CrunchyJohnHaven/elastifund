{
  "schema_version": 1,
  "description": "Candidate live maker-velocity fast-turn deployment. JJ is restricted to sub-1h crypto markets, with wallet-flow and LMSR enabled but the dedicated BTC 5-minute surface reserved for the standalone btc_5min_maker service. Live submission remains gated by wallet-flow readiness and the shared launch contract.",
  "mode": {
    "execution_mode": "live",
    "paper_trading": false,
    "allow_order_submission": true,
    "launch_gate": "wallet_flow_ready"
  },
  "feature_flags": {
    "enable_llm_signals": false,
    "enable_wallet_flow": true,
    "enable_lmsr": true,
    "enable_cross_platform_arb": false,
    "fast_flow_only": true,
    "enable_a6_shadow": false,
    "enable_a6_live": false,
    "enable_b1_shadow": false,
    "enable_b1_live": false,
    "enable_a6_embedded_shadow_scanner": false
  },
  "risk_limits": {
    "max_position_usd": 10.0,
    "max_daily_loss_usd": 390.0,
    "max_exposure_pct": 0.95,
    "kelly_fraction": 0.25,
    "max_kelly_fraction": 0.50,
    "scan_interval_seconds": 30,
    "max_open_positions": 30,
    "min_edge": 0.03,
    "initial_bankroll": 390.0,
    "hourly_notional_budget_usd": 390.0
  },
  "market_filters": {
    "max_resolution_hours": 1.0,
    "min_category_priority": 1,
    "category_priorities": {
      "politics": 0,
      "weather": 0,
      "economic": 0,
      "crypto": 3,
      "sports": 0,
      "financial_speculation": 0,
      "geopolitical": 0,
      "fed_rates": 0,
      "unknown": 0
    }
  },
  "signal_thresholds": {
    "yes_threshold": 0.05,
    "no_threshold": 0.02,
    "lmsr_entry_threshold": 0.03
  },
  "combinatorial_thresholds": {
    "a6_buy_threshold": 0.97,
    "a6_unwind_threshold": 1.03,
    "b1_implication_threshold": 0.03,
    "stale_book_max_age_seconds": 20,
    "fill_timeout_seconds": 2.0,
    "cancel_replace_count": 2,
    "max_notional_per_leg_usd": 5.0,
    "arb_budget_usd": 50.0,
    "merge_min_notional_usd": 10.0,
    "promotion_min_signals": 20,
    "required_capture_rate": 0.5,
    "required_classification_accuracy": 0.8,
    "max_false_positive_rate": 0.05,
    "max_consecutive_rollbacks": 3,
    "constraint_db_path": "data/constraint_arb.db",
    "dep_graph_db_path": "data/dep_graph.sqlite"
  },
  "microstructure_thresholds": {
    "vpin_bucket_size": 250.0,
    "vpin_window_size": 12,
    "vpin_toxic_threshold": 0.70,
    "vpin_safe_threshold": 0.20,
    "ws_heartbeat_interval_seconds": 5.0,
    "ws_rest_poll_interval_seconds": 2.0
  }
}
