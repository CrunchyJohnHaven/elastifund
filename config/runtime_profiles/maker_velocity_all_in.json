    "max_daily_loss_usd": 247.51,
    "max_exposure_pct": 1.0,
    "kelly_fraction": 1.0,
    "max_kelly_fraction": 1.0,
    "scan_interval_seconds": 15,
    "max_open_positions": 10,
    "min_edge": 0.01,
    "initial_bankroll": 247.51,
    "hourly_notional_budget_usd": 247.51
  },
  "market_filters": {
    "max_resolution_hours": 1.0,
    "min_category_priority": 1,
    "category_priorities": {
      "politics": 0,
      "weather": 0,
      "economic": 0,
      "crypto": 3,
      "sports": 0,
      "financial_speculation": 0,
      "geopolitical": 0,
      "fed_rates": 0,
      "unknown": 0
    }
  },
  "signal_thresholds": {
