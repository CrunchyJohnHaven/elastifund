    "enable_a6_shadow": false,
    "enable_a6_live": false,
    "enable_b1_shadow": false,
    "enable_b1_live": false,
    "enable_a6_embedded_shadow_scanner": true
  },
  "risk_limits": {
    "max_position_usd": 5.0,
    "max_daily_loss_usd": 5.0,
    "max_exposure_pct": 0.1,
    "kelly_fraction": 0.0625,
    "max_kelly_fraction": 0.125,
    "scan_interval_seconds": 60,
    "max_open_positions": 5,
    "min_edge": 0.04,
    "initial_bankroll": 247.51
  },
  "market_filters": {
    "max_resolution_hours": 4.0,
    "min_category_priority": 0,
    "category_priorities": {
      "politics": 0,
      "weather": 1,
