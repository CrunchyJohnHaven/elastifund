# Base BTC5 strategy parameters.
# The autoresearch loop can layer an override file on top of these values.
#
# 2026-03-14: Guardrail fixes — delta widened from 0.00015 to 0.0040,
# UP+DOWN both live, min_buy_price lowered to 0.42.

BTC5_MAX_ABS_DELTA=0.0040
BTC5_UP_MAX_BUY_PRICE=0.52
BTC5_DOWN_MAX_BUY_PRICE=0.53
BTC5_MIN_BUY_PRICE=0.42
BTC5_PROBE_MAX_ABS_DELTA=0.0040
BTC5_PROBE_UP_MAX_BUY_PRICE=0.52
BTC5_PROBE_DOWN_MAX_BUY_PRICE=0.53
