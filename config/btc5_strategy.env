# Base BTC5 strategy parameters.
# The autoresearch loop can layer an override file on top of these values.
#
# 2026-03-14: Guardrail fixes — delta widened from 0.00015 to 0.0040,
# UP+DOWN both live, min_buy_price lowered to 0.42.

BTC5_MAX_ABS_DELTA=0.0100
BTC5_UP_MAX_BUY_PRICE=0.52
BTC5_DOWN_MAX_BUY_PRICE=0.53
BTC5_MIN_BUY_PRICE=0.30
BTC5_PROBE_MAX_ABS_DELTA=0.0100
BTC5_PROBE_UP_MAX_BUY_PRICE=0.52
BTC5_PROBE_DOWN_MAX_BUY_PRICE=0.53

# Time-of-day filter (Instance 4).
# Disabled by default. Enable on VPS after deploy.
# Suppress hours = skip entirely (counterfactuals still logged).
# Boost hours = label only, no logic change (for analysis).
BTC5_HOUR_FILTER_ENABLED=false
BTC5_SUPPRESS_HOURS_ET=0,1,2,8,9
BTC5_BOOST_HOURS_ET=3,4,5,6,12,13,14,15,16,17,18,19

# Direction bias filter (Instance 5).
# Modes: both, down_only, up_only, down_bias
# Filter is disabled by default; enable after 200+ resolved trades.
BTC5_DIRECTION_FILTER_ENABLED=false
BTC5_DIRECTION_MODE=both
BTC5_DOWN_BIAS_THRESHOLD=0.60

# Rolling edge tracker: runs every N cycles (~every 8h at 100 cycles)
BTC5_EDGE_TRACKER_CYCLE_INTERVAL=100

# Adaptive suppression: pause trading if rolling win rate drops below threshold
BTC5_ADAPT_SUPPRESS_WR_THRESHOLD=0.35
BTC5_ADAPT_SUPPRESS_WINDOW_FILLS=20
