# Base BTC5 strategy parameters.
# 2026-03-25: Safety lockdown after -55.2% drawdown.
# UP direction KILLED (-$1,060 loss). DOWN-only mode. TOD filter ON.
# NOTE: BTC5_MAX_TRADE_USD lives in state/btc5_capital_stage.env, NOT here.
# auto_stage_gate.py now writes to that file instead.

BTC5_MAX_ABS_DELTA=0.0100
BTC5_UP_MAX_BUY_PRICE=0.52
BTC5_DOWN_MAX_BUY_PRICE=0.48
BTC5_MIN_BUY_PRICE=0.30
BTC5_PROBE_MAX_ABS_DELTA=0.0100
BTC5_PROBE_UP_MAX_BUY_PRICE=0.52
BTC5_PROBE_DOWN_MAX_BUY_PRICE=0.53

# Time-of-day filter: ENABLED. Suppress losing hours.
BTC5_TOD_FILTER_ENABLED=1
BTC5_TOD_SUPPRESS_HOURS_ET=0,1,2,8,9
BTC5_HOUR_FILTER_ENABLED=true
BTC5_SUPPRESS_HOURS_ET=0,1,2,8,9
BTC5_BOOST_HOURS_ET=3,4,5,6,12,13,14,15,16,17,18,19

# Direction filter: ENABLED. DOWN-ONLY mode.
# UP direction lost $1,060 on $1,492 deployed (24W/29L). Killed.
BTC5_DIRECTION_FILTER_ENABLED=true
BTC5_DIRECTION_MODE=down_only
BTC5_DOWN_BIAS_THRESHOLD=0.60

# UP live mode: shadow only (belt and suspenders with direction_mode)
BTC5_UP_LIVE_MODE=shadow_only

# Rolling edge tracker
BTC5_EDGE_TRACKER_CYCLE_INTERVAL=100

# Adaptive suppression: pause if win rate drops below 35%
BTC5_ADAPT_SUPPRESS_WR_THRESHOLD=0.35
BTC5_ADAPT_SUPPRESS_WINDOW_FILLS=20
