# Base BTC5 strategy parameters — restored 2026-03-15 post-merge
# Evidence base: 8/8 wins at price>=0.90, 0/2 wins below 0.90
# Momentum edge is symmetric: DOWN@0.90+ and UP@0.90+ both win.

# BTC5_MAX_ABS_DELTA — managed by delta_calibrator.py in state/btc5_capital_stage.env
# Do NOT set here — it would override the dynamic calibrator value.

# CRITICAL: These caps must be >= MIN_BUY_PRICE=0.90 to allow any trades
# UP: keep at 0.95. Data shows UP wins are marginal above this.
BTC5_UP_MAX_BUY_PRICE=0.95
# DOWN: raise to 0.98. Data: 6/6=100% at 0.97, 9/9=100% at 0.98.
# Do NOT go to 0.99 — EV is negative (88% WR at 0.01 payoff).
BTC5_DOWN_MAX_BUY_PRICE=0.98
BTC5_MIN_BUY_PRICE=0.42

# BTC5_PROBE_MAX_ABS_DELTA — let capital_stage.env value apply
BTC5_PROBE_UP_MAX_BUY_PRICE=0.95
BTC5_PROBE_DOWN_MAX_BUY_PRICE=0.98

# Both directions equal threshold (two_sided symmetric mode)
BTC5_MIN_DELTA=0.0001
BTC5_UP_MIN_DELTA=0.0001

# Phase 1.2: Expensive entry penalty fires above this price.
# Must be >= DOWN_MAX (0.98) so high-conviction DOWN entries aren't penalized.
BTC5_EXPENSIVE_ENTRY_PRICE_THRESHOLD=0.99

# H4-new: Toxic flow filter inverts at high prices (negative imbalance = agreement)
# Bypass when best_ask >= 0.90
BTC5_TOXIC_FLOW_MIN_PRICE_EXEMPT=0.90

# H4-mid: Midpoint kill zone blocks orders at 0.90+ that won't fill anyway
# Bypass when best_ask >= 0.90
BTC5_MIDPOINT_KILL_ZONE_MIN_PRICE_EXEMPT=0.90
