# ============================================================================
# Polymarket Trading Bot — LIVE DEPLOYMENT .env Template
# ============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.
#
# SAFETY LAYERS (all must pass for a live order):
#   1. NO_TRADE_MODE=false       (global kill-gate)
#   2. LIVE_TRADING=true          (broker selection)
#   3. Safety rails               (daily loss, per-trade cap, exposure, cooldown)
#   4. Risk manager               (position limits, rate limits, drawdown)
#   5. Kill switch                (DB-level emergency stop via /kill endpoint)
# ============================================================================

# ── POLYMARKET CREDENTIALS ──────────────────────────────────────────────────
# Private key for signing orders (NO 0x prefix)
POLYMARKET_PRIVATE_KEY=PASTE_PRIVATE_KEY_HERE
# Funder/proxy address on Polygon
POLYMARKET_FUNDER_ADDRESS=PASTE_FUNDER_ADDRESS_HERE
# CLOB API credentials (builder keys — get from Polymarket dashboard)
POLYMARKET_API_KEY=PASTE_API_KEY_HERE
POLYMARKET_API_SECRET=PASTE_API_SECRET_HERE
POLYMARKET_API_PASSPHRASE=PASTE_API_PASSPHRASE_HERE
# CLOB URL (mainnet default)
POLYMARKET_CLOB_URL=https://clob.polymarket.com
CHAIN_ID=137
SIGNATURE_TYPE=2

# ── ANTHROPIC (Claude AI) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-PASTE_ANTHROPIC_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
ENSEMBLE_ENABLED=false

# ── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///bot.db

# ── GLOBAL TRADING CONTROLS ────────────────────────────────────────────────
# NO_TRADE_MODE: Master kill-gate. Must be FALSE for ANY orders (paper or live).
# Leave TRUE until you've verified connectivity and are ready.
NO_TRADE_MODE=true
# LIVE_TRADING: When true, uses PolymarketBroker (real money). When false, PaperBroker.
LIVE_TRADING=false
# PAPER_TRADING: Legacy flag (overridden by LIVE_TRADING)
PAPER_TRADING=true

# ── ENGINE ──────────────────────────────────────────────────────────────────
ENGINE_LOOP_SECONDS=300
LOG_LEVEL=INFO
BOT_MODE=bot

# ── RISK MANAGEMENT ────────────────────────────────────────────────────────
# Max position size per market (USD)
MAX_POSITION_USD=100.0
# Max daily drawdown before auto kill switch (USD)
MAX_DAILY_DRAWDOWN_USD=10.0
# Max orders per hour (rate limit)
MAX_ORDERS_PER_HOUR=20

# ── SAFETY RAILS (NON-NEGOTIABLE) ──────────────────────────────────────────
# Hard cap per individual trade (even if Kelly says more)
MAX_PER_TRADE_USD=5.0
# Max exposure as fraction of bankroll (keep 20% cash reserve)
MAX_EXPOSURE_PCT=0.80
# Consecutive losses before cooldown triggers
COOLDOWN_CONSECUTIVE_LOSSES=3
# Cooldown duration (seconds) — 3600 = 1 hour
COOLDOWN_SECONDS=3600
# Cancel unfilled limit orders after N seconds
ORDER_TIMEOUT_SECONDS=60

# ── GRADUAL ROLLOUT (manual escalation — change these each week) ───────────
# Week 1: $1 max/trade, 3 trades/day, Kelly OFF
# Week 2: $2 max/trade, 5 trades/day, Kelly OFF
# Week 3: $5 max/trade, unlimited trades (-1), Kelly ON
ROLLOUT_MAX_PER_TRADE_USD=1.0
ROLLOUT_MAX_TRADES_PER_DAY=3
ROLLOUT_KELLY_ACTIVE=false

# ── TRADING PARAMETERS ─────────────────────────────────────────────────────
SLIPPAGE_BPS=10
FEE_BPS=0
MAX_POSITION_SIZE_USD=25.0
KELLY_FRACTION=0.5
CHECK_INTERVAL_SECONDS=300

# ── SCANNER COVERAGE ───────────────────────────────────────────────────────
# Fetch up to SCANNER_MAX_PAGES * 100 active markets, then filter by volume/liquidity.
SCANNER_MAX_PAGES=25
SCANNER_MIN_VOLUME=500
SCANNER_MIN_LIQUIDITY=50

# ── TELEGRAM NOTIFICATIONS ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=PASTE_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=PASTE_CHAT_ID_HERE

# ── DASHBOARD ───────────────────────────────────────────────────────────────
DASHBOARD_TOKEN=change_me_to_a_random_string

# ── NOAA WEATHER ────────────────────────────────────────────────────────────
NOAA_CITIES=Chicago,NYC,Dallas,Miami,Seattle,Atlanta
NOAA_BUY_BELOW=0.15
NOAA_SELL_ABOVE=0.45
NOAA_MAX_PER_POSITION=2.00

# ── NEWS SENTIMENT ──────────────────────────────────────────────────────────
NEWSDATA_API_KEY=
NEWS_ENRICHMENT_ENABLED=true
