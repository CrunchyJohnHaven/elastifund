# Polymarket Configuration
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_FUNDER_ADDRESS=your_funder_address_here
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_WS_URL=wss://ws.polymarket.com

# Blockchain Configuration
CHAIN_ID=137
SIGNATURE_TYPE=1

# Anthropic API (optional for Claude integration)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
ENSEMBLE_ENABLED=false

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///bot.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:password@localhost/polymarket_bot

# Application Settings
NO_TRADE_MODE=true
LIVE_TRADING=false
LOG_LEVEL=INFO
ENGINE_LOOP_SECONDS=60

# Risk Management
MAX_POSITION_USD=100.0
MAX_DAILY_DRAWDOWN_USD=50.0
MAX_ORDERS_PER_HOUR=20

# Trading Parameters
SLIPPAGE_BPS=10
FEE_BPS=0

# Scanner coverage
SCANNER_MAX_PAGES=25
SCANNER_MIN_VOLUME=500
SCANNER_MIN_LIQUIDITY=50

# Dashboard & Notifications
DASHBOARD_TOKEN=change_me
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional Elastic Stack telemetry
ELASTIC_TELEMETRY_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTIC_PASSWORD=
ELASTICSEARCH_VERIFY_CERTS=false
ELASTIC_AGENT_ID=polymarket-bot
ELASTIC_AGENT_NAME=Polymarket Bot
ELASTIC_AGENT_TYPE=trading_bot
ELASTIC_STRATEGY_ID=
ELASTIC_AGENTS_ALIAS=elastifund-agents
ELASTIC_TRADES_ALIAS=elastifund-trades
ELASTIC_METRICS_DATA_STREAM=elastifund-metrics
