          "reason"
        ],
        "title": "KillSwitchRequest",
        "type": "object"
      },
      "RiskLimitsResponse": {
        "properties": {
          "max_daily_drawdown_usd": {
            "title": "Max Daily Drawdown Usd",
            "type": "number"
          },
          "max_orders_per_hour": {
            "title": "Max Orders Per Hour",
            "type": "integer"
          },
          "max_position_usd": {
            "title": "Max Position Usd",
            "type": "number"
          }
        },
        "required": [
          "max_position_usd",
          "max_daily_drawdown_usd",
          "max_orders_per_hour"
        ],
        "title": "RiskLimitsResponse",
        "type": "object"
      },
      "RiskLimitsUpdate": {
        "properties": {
          "max_daily_drawdown_usd": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Daily Drawdown Usd"
          },
          "max_orders_per_hour": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Orders Per Hour"
          },
          "max_position_usd": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Position Usd"
