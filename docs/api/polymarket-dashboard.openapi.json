        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "title": "Status",
            "type": "string"
          },
          "uptime_seconds": {
            "title": "Uptime Seconds",
            "type": "integer"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "version",
          "uptime_seconds"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "KillSwitchRequest": {
