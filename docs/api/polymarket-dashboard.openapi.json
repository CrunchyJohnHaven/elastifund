  "info": {
    "description": "OpenAPI export for the Polymarket dashboard and control API used by the current Elastifund trading stack. Authentication behavior is documented in docs/api/README.md because the runtime uses custom FastAPI dependencies rather than OpenAPI security helpers.",
    "title": "Polymarket Bot Dashboard",
    "version": "0.2.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "description": "Serve the static HTML dashboard.",
        "operationId": "dashboard_page__get",
        "responses": {
          "200": {
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Dashboard Page"
      }
    },
    "/api/dashboard-data": {
      "get": {
        "description": "Aggregated dashboard data for the web UI.",
        "operationId": "dashboard_data_api_dashboard_data_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Dashboard Data"
      }
    },
    "/api/equity-curve": {
      "get": {
        "description": "Return daily portfolio snapshots for Chart.js equity curve.",
        "operationId": "equity_curve_api_equity_curve_get",
